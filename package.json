{
  "name": "emberwake",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "performance:validate": "node scripts/performance/validateRuntimeBudgets.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser:smoke": "npm run build && node scripts/testing/runBrowserSmoke.mjs",
    "test:browser:profile:long": "npm run build && node scripts/testing/runLongSessionProfile.mjs",
    "logics:lint": "python3 logics/skills/logics-doc-linter/scripts/logics_lint.py",
    "release:ready": "node scripts/release/verifyReleaseReadiness.mjs",
    "release:ready:advisory": "node scripts/release/verifyReleaseReadiness.mjs --allow-non-release",
    "release:changelog:resolve": "node scripts/release/resolveReleaseChangelog.mjs",
    "release:changelog:validate": "node scripts/release/validateReleaseChangelog.mjs",
    "release:postdeploy:smoke": "node scripts/release/runPostDeploySmoke.mjs",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build && npm run performance:validate && npm run logics:lint",
    "ci:full": "npm run ci && npm run test:browser:smoke"
  },
  "dependencies": {
    "@pixi/react": "^8.0.3",
    "pixi.js": "^8.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.58.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.8"
  }
}
