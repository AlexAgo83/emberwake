{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "vitest/globals"],
    "paths": {
      "@app/*": ["src/app/*"],
      "@assets/*": ["src/assets/*"],
      "@engine/*": ["packages/engine-core/src/*"],
      "@engine-pixi/*": ["packages/engine-pixi/src/*"],
      "@game/*": ["games/emberwake/src/*"],
      "@shared/*": ["src/shared/*"],
      "@src/*": ["src/*"]
    }
  },
  "include": ["src", "apps", "games", "packages"]
}
